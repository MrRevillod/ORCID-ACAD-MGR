		"axios": "^1.17.0",
		"country-list-spanish": "^0.3.2",
		"dompurify": "^3.3.0",
		"runed": "^0.37.1",
		"svelte-sonner": "^1.1.1",
		"valibot": "^1.4.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",

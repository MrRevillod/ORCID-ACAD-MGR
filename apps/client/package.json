		"lint": "prettier --check --config ../../.prettierrc --ignore-path ../../.prettierignore . && eslint .",
		"format": "prettier --write --config ../../.prettierrc --ignore-path ../../.prettierignore ."
	},
	"packageManager": "pnpm@11.6.0",
	"dependencies": {
